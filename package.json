{
  "name": "apptemplate-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AppTemplate - Fullstack Application Scaffolding Tool",
  "scripts": {
    "prepare": "husky",
    "sync-versions": "npx tsx scripts/sync-versions.ts",
    "check-versions": "npx tsx scripts/check-versions.ts",
    "check-parity": "npx tsx scripts/check-parity.ts",
    "integration-test": "npx tsx scripts/integration-test.ts",
    "test:e2e": "vitest run --config tests/vitest.config.ts",
    "test:e2e:quick": "vitest run --config tests/vitest.config.quick.ts",
    "test:e2e:full": "vitest run --config tests/vitest.config.full.ts",
    "test:e2e:contract": "vitest run --config tests/vitest.config.contract.ts",
    "test:e2e:watch": "vitest --config tests/vitest.config.quick.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@vitest/coverage-v8": "^3.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "vitest": "^3.2.3"
  },
  "lint-staged": {
    "frontend-vuetify/**/*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend-primevue/**/*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend-mui/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend-primereact/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "create-apptemplate/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
